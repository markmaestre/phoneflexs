.home-container {
  padding-top: 60px; /* Adjust this value based on your navbar height */
}

/* Navbar styles */
.navbar {
  margin-bottom: 20px; /* Space below the navbar */
}

/* Carousel styles */
.promo-carousel {
  max-height: 500px; /* Set a maximum height for the carousel */
}

.carousel-content {
  display: flex; /* Use flexbox to align items */
  justify-content: flex-end; /* Align items to the right */
  align-items: bottom; /* Center items vertically */
  height: 100%; /* Full height for the carousel */
  padding: 20px; /* Padding for the content */
}

.product-image {
  max-width: 300px; /* Set a maximum width for images */
  height: auto; /* Maintain aspect ratio */
  margin-left: 20px; /* Space between the image and the text */
}

.promo-text {
  text-align: right; /* Align text to the right */
  color: #333; /* Adjust color as needed */
}

.product-title {
  font-size: 1.5rem; /* Adjust font size */
  margin: 10px 0; /* Space around title */
}

.product-subtitle {
  font-size: 1rem; /* Adjust subtitle font size */
  margin-bottom: 15px; /* Space below subtitle */
}

.learn-more-button {
  background-color: #007bff; /* Bootstrap primary color */
  color: white; /* Text color */
  border: none; /* No border */
  padding: 10px 20px; /* Padding for button */
  border-radius: 5px; /* Rounded corners */
  cursor: pointer; /* Pointer cursor */
  transition: background-color 0.3s; /* Smooth transition */
}

.learn-more-button:hover {
  background-color: #0056b3; /* Darker shade on hover */
}

/* Faster carousel slide transition */
.promo-carousel .carousel-item {
  transition: transform 1s ease-in-out; /* Adjust to desired speed */
}

/* Product Section Styles */
.product-section {
  margin: 40px 20px;
  text-align: center;
}

.section-title {
  font-size: 1.8rem;
  margin-bottom: 20px;
  color: #333;
}

/* Product grid layout */
.product-grid {
  display: flex;
  justify-content: center;
  gap: 20px;
  flex-wrap: wrap; /* Allow wrapping for smaller screens */
}

.product-card {
  background-color: #f8f8f8;
  padding: 20px;
  border-radius: 8px;
  width: 250px;
  text-align: center;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.product-card:hover {
  transform: translateY(-5px); /* Lift effect on hover */
  box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
}

.product-card-image {
  max-width: 100%;
  height: auto;
  margin-bottom: 15px;
}

.product-card h3 {
  font-size: 1.25rem;
  margin: 10px 0;
}

.product-btn {
  width: 100%;
  margin-top: 10px;
  font-weight: bold;
}

.product-btn:first-of-type {
  margin-top: 15px; /* Space above the first button */
}

.product-btn.primary {
  background-color: #007bff;
  border: none;
  color: white;
}

.product-btn.success {
  background-color: #28a745;
  border: none;
  color: white;
}

.product-btn.primary:hover {
  background-color: #0056b3;
}

.product-btn.success:hover {
  background-color: #218838;
}
